{
  "$schema": "../node_modules/@angular-devkit/schematics/collection-schema.json",
  "schematics": {
    "model": {
      "description": "Genera un modelo",
      "factory": "./model/index.js",
      "schema": "./model/schema.json"
    },
    "domain": {
      "description": "Genera estructura del dominio (models, types, services, helpers)",
      "factory": "./domain/index#default",
      "schema": "./domain/schema.json"
    },
    "page": {
      "description": "Generate a page",
      "factory": "./page/index#default",
      "schema": "./page/schema.json"
    },
    "service": {
      "description": "service",
      "factory": "./service/index#service",
      "schema": "./service/schema.json"
    }
  }
}