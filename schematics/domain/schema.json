{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "DomainSchematics",
  "title": "Domain Generator",
  "type": "object",
  "description": "Genera estructura de dominio completa (models, types, service, helpers).",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre del dominio",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    }
  },
  "required": ["name"]
}
