{
  "$schema": "http://json-schema.org/schema",
  "$id": "modelSchema",
  "title": "Model Generator",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nombre del modelo",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    },
    "id": {
      "type": "string",
      "description": "Nombre del ID si no se usa JSON"
    },
    "props": {
      "type": "string",
      "description": "Propiedades en formato key:type,key:type"
    },
    "useJson": {
      "type": "boolean",
      "description": "Forzar uso de JSON",
      "default": true
    }
  },
  "required": ["name"]
}
